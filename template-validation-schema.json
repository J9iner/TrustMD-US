{
  "templateSchema": {
    "required": ["id", "name", "category", "requirements", "version", "lastUpdated"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "minLength": 3,
        "maxLength": 50,
        "description": "Unique template identifier"
      },
      "name": {
        "type": "string",
        "minLength": 3,
        "maxLength": 100,
        "description": "Human-readable template name"
      },
      "category": {
        "type": "string",
        "enum": ["federal", "state", "specialty", "custom"],
        "description": "Template category classification"
      },
      "version": {
        "type": "string",
        "pattern": "^\\d+\\.\\d+\\.\\d+$",
        "description": "Semantic version (e.g., 1.0.0)"
      },
      "requirements": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["id", "title", "description", "points"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9_-]+$",
              "minLength": 1,
              "maxLength": 50
            },
            "title": {
              "type": "string",
              "minLength": 3,
              "maxLength": 200
            },
            "description": {
              "type": "string",
              "minLength": 10,
              "maxLength": 1000
            },
            "points": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "mandatory": {
              "type": "boolean",
              "default": false
            },
            "riskLevel": {
              "type": "string",
              "enum": ["critical", "high", "medium", "low"],
              "default": "medium"
            },
            "evidenceRequired": {
              "type": "boolean",
              "default": false
            },
            "expirationDays": {
              "type": "integer",
              "minimum": 0,
              "maximum": 3650
            }
          }
        }
      },
      "sections": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["id", "title", "requirements"],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^[a-z0-9_-]+$"
            },
            "title": {
              "type": "string",
              "minLength": 3,
              "maxLength": 100
            },
            "description": {
              "type": "string",
              "maxLength": 500
            },
            "requirements": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "metadata": {
        "type": "object",
        "properties": {
          "author": {
            "type": "string",
            "maxLength": 100
          },
          "created": {
            "type": "string",
            "format": "date-time"
          },
          "lastUpdated": {
            "type": "string",
            "format": "date-time"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 50
            }
          },
          "complianceFrameworks": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["HIPAA", "HITECH", "MACRA", "MIPS", "PCI-DSS", "SOC2", "NIST", "ISO27001"]
            }
          }
        }
      }
    }
  },
  "validationRules": {
    "maxRequirementsPerTemplate": 100,
    "maxSectionsPerTemplate": 20,
    "maxPointsPerRequirement": 100,
    "maxTotalPoints": 1000,
    "mandatoryRequirementsLimit": 50,
    "criticalRequirementsLimit": 20,
    "versionIncrementRules": {
      "major": "Breaking changes",
      "minor": "New features or requirements",
      "patch": "Bug fixes or text updates"
    },
    "securityChecks": {
      "noScriptInjections": true,
      "noSqlInjections": true,
      "noXssPatterns": true,
      "validateHtmlContent": true
    }
  },
  "integrityChecks": {
    "checksumValidation": true,
    "digitalSignature": false,
    "tamperDetection": true,
    "versionConsistency": true
  },
  "errorHandling": {
    "strictMode": true,
    "logValidationErrors": true,
    "returnDetailedErrors": true,
    "allowPartialValidation": false
  }
}
